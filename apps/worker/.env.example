# Copy to `.env.local` (gitignored).
# `bun run dev:worker` will create `.env.local` from this file if it is missing.
# It will also generate local-only values for `JWT_SECRET`, `X_REFRESH_TOKEN_ENC_KEY`,
# and `X_REFRESH_TOKEN_ENC_KID` when those entries are blank.
# Used by: `wrangler dev`, `wrangler deploy --dry-run` (with `--env-file .env.local`).
#
# OAuth 2.0 **User authentication** client id/secret (PKCE) from the X developer portal — not the legacy API key/secret pair.

JWT_SECRET=

X_CLIENT_ID=
X_CLIENT_SECRET=
#
# Base64-encoded 32 byte AES-GCM key used to encrypt X refresh tokens at rest.
# Generate one with: `openssl rand -base64 32`
X_REFRESH_TOKEN_ENC_KEY=
X_REFRESH_TOKEN_ENC_KID=v1

# Committed Env typings (`worker-configuration.d.ts`) are generated via `.env.cf-generate` — run `bun run cf-types`.
