{
  "name": "@jamful/worker",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run dev:setup && bun run migrate:local && portless api.jamful sh -c 'wrangler dev --ip \"${HOST:-127.0.0.1}\" --port \"${PORT:-8787}\"'",
    "dev:setup": "bun ./scripts/dev-setup.ts",
    "build": "wrangler deploy --dry-run",
    "build:production": "wrangler deploy --dry-run",
    "migrate:local": "wrangler d1 migrations apply JAMFUL_D1 --local",
    "migrate:production": "wrangler d1 migrations apply JAMFUL_D1 --remote",
    "deploy:production": "wrangler deploy",
    "deploy": "bun run build:production && bun run migrate:production && bun run deploy:production",
    "cf-types": "wrangler types",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@jamful/shared": "workspace:*",
    "jose": "^6.2.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "portless": "^0.10.3",
    "typescript": "^5.7.0",
    "wrangler": "^4.28.0"
  }
}
