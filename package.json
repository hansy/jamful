{
  "name": "jamful",
  "private": true,
  "packageManager": "bun@1.3.4",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "@vitejs/plugin-react": "4.7.0"
  },
  "scripts": {
    "build": "bun run build:worker && bun run build:extension",
    "build:worker": "bun run --cwd apps/worker build",
    "build:production": "bun run --cwd apps/worker build:production && bun run build:extension",
    "build:extension": "bun run --cwd apps/extension build",
    "build:extension:firefox": "bun run --cwd apps/extension build:firefox",
    "build:extension:safari": "bun run --cwd apps/extension build:safari",
    "zip:extension": "bun run --cwd apps/extension zip",
    "zip:extension:firefox": "bun run --cwd apps/extension zip:firefox",
    "deploy:worker": "bun run --cwd apps/worker deploy",
    "assets:brand": "bun scripts/generate-brand-assets.ts",
    "registry": "bun scripts/build-registry.ts",
    "dev:worker": "bun run --cwd apps/worker dev",
    "dev:website": "bun run --cwd apps/website dev",
    "dev:extension": "bun run --cwd apps/extension dev",
    "typecheck": "tsc -p packages/shared/tsconfig.json && tsc -p packages/extension-core/tsconfig.json && tsc -p packages/extension-api/tsconfig.json && tsc -p apps/worker/tsconfig.json && tsc -p apps/extension/tsconfig.json && tsc -p scripts/tsconfig.json",
    "cf-types": "bun run --cwd apps/worker cf-types"
  },
  "devDependencies": {
    "sharp": "^0.34.5",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
